# ============================================
# CONFIGURAÇÃO DO SISTEMA MERCADINHO PDV
# ============================================
# Copie este arquivo para .env e configure

# ============================================
# MODO DE OPERAÇÃO
# ============================================
DATABASE_MODE=local

# ============================================
# BANCO DE DADOS LOCAL
# ============================================
DATABASE_URL="postgresql://postgres:postgres123@localhost:5432/mercadinho_local"

# ============================================
# SINCRONIZAÇÃO
# ============================================
SYNC_ENABLED=true
VPS_API_URL=https://seu-servidor.com/api
SYNC_TOKEN=seu_token_jwt_aqui

# ============================================
# SERVIDOR
# ============================================
PORT=3001
NODE_ENV=development

# ============================================
# SEGURANÇA
# ============================================
JWT_SECRET=sua_chave_secreta_minimo_32_caracteres
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000

# ============================================
# LICENCIAMENTO
# ============================================
# Secret para tokens de licença (pode ser diferente do JWT_SECRET)
JWT_LICENSE_SECRET=chave_secreta_para_licencas_32_caracteres

